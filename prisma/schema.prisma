generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Jurisdiction {
  id             String          @id @default(uuid())
  name           String
  code           String          @unique
  country        String
  type           String
  description    String?
  website        String?
  currency       String          @default("USD")
  treatyPartners String[]
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Sub-jurisdiction hierarchy
  parentId         String?
  parent           Jurisdiction?  @relation("SubJurisdictions", fields: [parentId], references: [id])
  subJurisdictions Jurisdiction[] @relation("SubJurisdictions")

  // Feed monitoring
  feedUrl         String?
  feedLastChecked DateTime?
  feedLastHash    String?

  incentiveRules         IncentiveRule[]
  productions            Production[]
  localRules             LocalRule[]
  pendingRules           PendingRule[]
  childPolicies          InheritancePolicy[] @relation("ChildPolicies")
  parentPolicies         InheritancePolicy[] @relation("ParentPolicies")
  subJurisdictionModels  SubJurisdiction[]   @relation("SubJurisdictionModel")

  @@index([parentId])
  @@map("jurisdictions")
}

model LocalRule {
  id             String       @id @default(uuid())
  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  name           String
  code           String       @unique
  category       String
  ruleType       String
  amount         Float?
  percentage     Float?
  description    String
  requirements   String?
  effectiveDate  DateTime
  expirationDate DateTime?
  sourceUrl      String?
  extractedBy    String       @default("manual")
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([jurisdictionId])
  @@map("local_rules")
}

model InheritancePolicy {
  id                  String       @id @default(uuid())
  childJurisdictionId String
  parentJurisdictionId String
  child               Jurisdiction @relation("ChildPolicies", fields: [childJurisdictionId], references: [id], onDelete: Cascade)
  parent              Jurisdiction @relation("ParentPolicies", fields: [parentJurisdictionId], references: [id], onDelete: Cascade)
  policyType          String
  ruleCategory        String?
  priority            Int          @default(0)
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@unique([childJurisdictionId, parentJurisdictionId, ruleCategory])
  @@index([childJurisdictionId])
  @@index([parentJurisdictionId])
  @@map("inheritance_policies")
}

model PendingRule {
  id             String       @id @default(uuid())
  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  sourceUrl      String
  rawContent     String
  extractedData  Json
  confidence     Float?
  status         String       @default("pending")
  reviewNotes    String?
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([jurisdictionId])
  @@index([status])
  @@map("pending_rules")
}

model IncentiveRule {
  id               String       @id @default(uuid())
  jurisdictionId   String
  jurisdiction     Jurisdiction @relation(fields:  [jurisdictionId], references: [id], onDelete: Cascade)
  ruleName         String
  ruleCode         String       @unique
  incentiveType    String
  percentage       Float?
  fixedAmount      Float?
  minSpend         Float?
  maxCredit        Float?
  eligibleExpenses String[]
  excludedExpenses String[]
  creditType       String       @default("refundable")
  effectiveDate    DateTime
  expirationDate   DateTime?
  requirements     String?
  active           Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([jurisdictionId])
  @@map("incentive_rules")
}

model Production {
  id                String           @id @default(uuid())
  title             String
  productionType    String
  jurisdictionId    String
  jurisdiction      Jurisdiction     @relation(fields: [jurisdictionId], references: [id])
  budgetTotal       Float
  budgetQualifying  Float?
  startDate         DateTime
  endDate           DateTime?
  productionCompany String
  status            String
  contact           String?
  metadata          String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  expenses          Expense[]
  complianceItems   ComplianceItem[]
  scenarios         ProductionScenario[]

  @@index([jurisdictionId])
  @@index([status])
  @@map("productions")
}

model Expense {
  id             String     @id @default(uuid())
  productionId   String
  production     Production @relation(fields:  [productionId], references: [id], onDelete: Cascade)
  category       String
  subcategory    String?
  description    String
  amount         Float
  expenseDate    DateTime
  paymentDate    DateTime?
  isQualifying   Boolean    @default(true)
  qualifyingNote String?
  vendorName     String?
  vendorLocation String?
  receiptNumber  String?
  invoiceNumber  String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([productionId])
  @@index([expenseDate])
  @@map("expenses")
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  passwordHash           String
  role                   String                  @default("admin")
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  notificationPreference NotificationPreference?

  @@map("users")
}

model ComplianceItem {
  id           String     @id @default(uuid())
  productionId String
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  label        String
  category     String     @default("general")
  status       String     @default("pending")
  notes        String?
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([productionId])
  @@map("compliance_items")
}

model NotificationPreference {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jurisdictions String[]
  emailAddress  String
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("notification_preferences")
}

model MonitoringSource {
  id           String            @id @default(uuid())
  name         String
  url          String
  feedUrl      String?
  sourceType   String            @default("rss")
  jurisdiction String?
  active       Boolean           @default(true)
  lastFetched  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  events       MonitoringEvent[]

  @@map("monitoring_sources")
}

model MonitoringEvent {
  id          String           @id @default(uuid())
  sourceId    String
  source      MonitoringSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  title       String
  summary     String?
  url         String?
  contentHash String?
  severity    String           @default("info")
  isRead      Boolean          @default(false)
  publishedAt DateTime?
  createdAt   DateTime         @default(now())

  @@index([sourceId])
  @@index([isRead])
  @@index([createdAt])
  @@map("monitoring_events")
}

// ─── Phase 0: Sub-Jurisdiction Layer ──────────────────────────────────────────

/// County, city, region, or special-district incentive that stacks on top of
/// the base state credit. Links to the parent Jurisdiction via parentJurisdictionId.
model SubJurisdiction {
  id                            String    @id @default(uuid())

  name                          String
  // county | city | region | special_district
  type                          String
  parentJurisdictionId          String
  parentJurisdiction            Jurisdiction @relation("SubJurisdictionModel", fields: [parentJurisdictionId], references: [id], onDelete: Restrict)

  // credit | rebate | fee_waiver | in_kind
  incentiveType                 String
  ratePercent                   Float?
  fixedAmount                   Float?
  capPerProduction              Float?
  annualCap                     Float?
  minSpendRequired              Float?

  // Stacking rules JSON: cannot_stack_with[], requires[], stacking_order, notes
  stackingRules                 Json      @default("{}")
  eligibleExpenditureCategories Json?
  localHirePercentageRequired   Float?

  effectiveDate                 DateTime  @db.Date
  expirationDate                DateTime? @db.Date

  isActive                      Boolean   @default(true)
  sourceUrl                     String?
  lastVerified                  DateTime?
  notes                         String?

  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  @@index([parentJurisdictionId])
  @@map("sub_jurisdictions")
}

/// Stores "what-if" input parameters for a single production.
/// Multiple scenarios per production allow baseline vs. optimized comparison.
model ProductionScenario {
  id                  String    @id @default(uuid())
  productionId        String
  production          Production @relation(fields: [productionId], references: [id], onDelete: Cascade)

  name                String
  totalBudget         Float?
  qualifiedSpend      Float?
  /// e.g. {"labor": 5000000, "rentals": 2000000}
  spendByCategory     Json?
  shootingDays        Int?
  /// e.g. [{"jurisdiction_id": "uuid", "days": 20}, {"sub_jurisdiction_id": "uuid", "days": 10}]
  daysByJurisdiction  Json?
  postLocation        String?
  localHirePercent    Float?
  hireByJurisdiction  Json?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  optimizationResult  ScenarioOptimizationResult?

  @@index([productionId])
  @@map("production_scenarios")
}

/// Cached stacking-engine output for a given scenario.
/// Set expiresAt to force recomputation when underlying data changes.
model ScenarioOptimizationResult {
  id                  String             @id @default(uuid())
  scenarioId          String             @unique
  scenario            ProductionScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  /// e.g. [{"jurisdiction_id": "...", "name": "NY Base", "incentive_value": 4500000}]
  recommendedStack    Json               @default("[]")
  totalIncentiveValue Float?
  effectiveRate       Float?
  /// e.g. "refundable within 90 days of audit"
  cashFlowEstimate    String?
  /// e.g. ["Annual cap 82% exhausted — apply early"]
  warnings            Json?

  createdAt           DateTime           @default(now())
  expiresAt           DateTime?

  @@map("scenario_optimization_results")
}
